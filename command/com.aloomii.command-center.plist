<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.aloomii.command-center</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/superhana/Desktop/aloomii/command/deploy.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/superhana/Desktop/aloomii/command</string>

